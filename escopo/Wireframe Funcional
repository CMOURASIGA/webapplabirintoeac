│                              │
│        ┌───┬───┬───┬───┐     │
│        │ P │ X │ M │ O │     │
│        ├───┼───┼───┼───┤     │
│        │ E │ R │ D │ A │     │
│        ├───┼───┼───┼───┤     │
│        │ B │ C │ A │ O │     │
│        ├───┼───┼───┼───┤     │
│        │ F │ G │ H │ O │     │
